// Prisma schema - Website quản lý đặt lịch khám bệnh tích hợp chatbot
// Flow chính:
// - Bệnh nhân không cần đăng ký tài khoản
// - Đặt lịch bằng số điện thoại + OTP
// - Email khuyến khích nhập để nhận phiếu hẹn/kết quả
// - Tra cứu lịch hẹn bằng số điện thoại
// - Tra cứu kết quả bằng số điện thoại + OTP hoặc mã vạch hóa đơn
// - Admin/Staff/Doctor có tài khoản đăng nhập

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===================== ENUMS =====================

enum Role {
  ADMIN
  STAFF
  DOCTOR
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  PENDING_OTP // Đã tạo lịch nhưng chưa xác thực OTP
  PENDING_CONFIRM // Đã xác thực OTP, chờ nhân viên/bác sĩ xác nhận
  CONFIRMED // Đã xác nhận lịch khám
  CHECKED_IN // Bệnh nhân đã đến/check-in
  IN_PROGRESS // Đang khám
  COMPLETED // Đã khám xong
  RESCHEDULED // Đã được dời lịch
  CANCELLED_BY_PATIENT // Bệnh nhân hủy
  CANCELLED_BY_DOCTOR // Bác sĩ hủy
  CANCELLED_BY_ADMIN // Admin/Staff hủy
  NO_SHOW // Bệnh nhân không đến
}

enum OtpPurpose {
  BOOK_APPOINTMENT
  LOOKUP_APPOINTMENT
  PATIENT_PORTAL_LOGIN
  CANCEL_APPOINTMENT
  LOOKUP_RESULT
  ADMIN_LOGIN
  DOCTOR_LOGIN
  STAFF_LOGIN
}

enum OtpChannel {
  SMS
  EMAIL
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOMO
  VNPAY
  OTHER
}

enum PaymentProvider {
  MOCK
  VNPAY
  MOMO
  ZALOPAY
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  EXPIRED
}

enum ConsultationStatus {
  NEW
  CONTACTED
  CANCELLED
  COMPLETED
}

enum MedicalResultStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PrescriptionStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum AppointmentLogAction {
  APPOINTMENT_CREATED
  OTP_SENT
  OTP_VERIFIED
  CONFIRMED
  RESCHEDULED
  CANCELLED_BY_PATIENT
  CANCELLED_BY_DOCTOR
  CANCELLED_BY_ADMIN
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  MEDICAL_RESULT_CREATED
  INVOICE_CREATED
}

enum ScheduleChangeType {
  CREATE_SLOT
  UPDATE_SLOT
  LOCK_SLOT
  UNLOCK_SLOT
  DELETE_SLOT
  UPDATE_WEEKLY_SCHEDULE
}

enum TimeSlotStatus {
  AVAILABLE
  BOOKED
  LOCKED
  CANCELLED
}

enum MediaOwnerType {
  DEPARTMENT
  USER_AVATAR
  DOCTOR
  PACKAGE
  MEDICAL_RESULT
  BANNER
  SITE_SETTING
}

// ===================== USERS =====================

model User {
  id       String  @id @default(uuid())
  fullName String
  email    String? @unique
  phone    String? @unique
  password String?
  role     Role    @default(PATIENT)
  avatar   String?

  isPhoneVerified Boolean @default(false)
  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(true)

  // Patient relations
  patientProfile PatientProfile?
  appointments   Appointment[]   @relation("PatientAppointments")
  medicalRecords MedicalRecord[] @relation("PatientRecords")
  invoices       Invoice[]       @relation("PatientInvoices")
  prescriptions  Prescription[]  @relation("PatientPrescriptions")

  // Doctor relation
  doctorProfile DoctorProfile?

  // Common relations
  chatbotLogs ChatbotLog[]
  chatbotSessions ChatbotSession[]
  otpCodes    OtpCode[]
  dashboardLoginChallenges DashboardLoginChallenge[]
  mediaAssets MediaAsset[]

  // Logs created by Admin/Staff/Doctor
  appointmentLogs AppointmentLog[]
  scheduleLogs    ScheduleChangeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
  @@index([role])
}

model PatientProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dateOfBirth DateTime?
  gender      Gender?
  cccd        String?   @unique
  address     String?

  // BHYT
  hasBHYT             Boolean @default(false)
  healthInsuranceCode String?
  registeredHospital  String?

  // Thông tin sức khỏe cơ bản
  bloodType      String?
  height         Float?
  weight         Float?
  allergies      String?
  medicalHistory String?
  familyHistory  String?
  bloodPressure  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== OTP =====================

model OtpCode {
  id      String     @id @default(uuid())
  phone   String
  email   String?
  target  String?
  channel OtpChannel @default(SMS)
  code    String
  purpose OtpPurpose

  ipAddress String?
  challengeId String?
  challenge   DashboardLoginChallenge? @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedAt    DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([email])
  @@index([target])
  @@index([channel])
  @@index([purpose])
  @@index([expiresAt])
  @@index([ipAddress])
  @@index([challengeId])
}

model OtpSecurityBlock {
  id String @id @default(uuid())

  targetType String
  target     String
  reason     String
  purpose    OtpPurpose?

  blockedUntil DateTime
  createdAt    DateTime @default(now())

  @@index([targetType, target])
  @@index([purpose])
  @@index([blockedUntil])
}

model OtpVerifyAttempt {
  id String @id @default(uuid())

  phone     String
  email     String?
  target    String?
  channel   OtpChannel @default(SMS)
  purpose   OtpPurpose
  ipAddress String?
  success   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([phone, purpose, createdAt])
  @@index([target, channel, purpose, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success])
}

model DashboardLoginChallenge {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  purpose   OtpPurpose
  ipAddress String?

  attempts Int @default(0)
  isUsed   Boolean @default(false)
  usedAt   DateTime?

  expiresAt DateTime
  createdAt DateTime @default(now())

  otpCodes OtpCode[]

  @@index([userId])
  @@index([expiresAt])
  @@index([isUsed])
}

model MediaAsset {
  id String @id @default(uuid())

  url      String
  publicId String @unique

  folder   String
  mimeType String?
  format   String?
  bytes    Int?
  width    Int?
  height   Int?

  ownerType MediaOwnerType?
  ownerId   String?
  isUsed    Boolean @default(false)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerType, ownerId])
  @@index([isUsed])
  @@index([uploadedById])
  @@index([createdAt])
}

// ===================== DEPARTMENT / DOCTOR =====================

model Department {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String? @unique
  description String?
  image       String?
  isActive    Boolean @default(true)

  doctors      DoctorProfile[]
  appointments Appointment[]
  packages     Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  title           String?
  bio             String?
  specialization  String?
  experience      Int?
  consultationFee Int     @default(0)

  isAvailable Boolean @default(true)

  appointments       Appointment[]       @relation("DoctorAppointments")
  schedules          DoctorSchedule[]
  timeSlots          DoctorTimeSlot[]
  medicalRecords     MedicalRecord[]     @relation("DoctorRecords")
  prescriptions       Prescription[]      @relation("DoctorPrescriptions")
  reviews            Review[]
  scheduleChangeLogs ScheduleChangeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
}

// Lịch làm việc lặp lại theo tuần của bác sĩ
// Ví dụ: Thứ 2, 08:00 - 11:30
model DoctorSchedule {
  id       String        @id @default(uuid())
  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  // Lịch mẫu theo tuần
  // VD: Thứ 2, 08:00 - 11:30, mỗi ca 30 phút
  dayOfWeek Int // 0: Chủ nhật, 1: Thứ 2, ...
  startTime String
  endTime   String

  slotDuration Int     @default(30) // phút
  maxPatients  Int     @default(1)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([dayOfWeek])
}

// Slot khám cụ thể theo ngày để đặt lịch, chống trùng lịch
model DoctorTimeSlot {
  id       String        @id @default(uuid())
  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  // Slot cụ thể theo ngày thật
  // VD: 2026-05-20, 08:00 - 08:30
  date      DateTime
  startTime String
  endTime   String

  status   TimeSlotStatus @default(AVAILABLE)
  isActive Boolean        @default(true)

  // Lý do khóa/hủy slot, ví dụ: bác sĩ nghỉ đột xuất, họp chuyên môn
  lockReason String?

  appointment Appointment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, date, startTime])
  @@index([doctorId])
  @@index([date])
  @@index([status])
}

// ===================== PACKAGES =====================

// Gói khám tổng quan
// Ví dụ: Khám tổng quát, Khám chuyên khoa, Gói sàng lọc ban đầu
model Package {
  id          String  @id @default(uuid())
  name        String
  slug        String? @unique
  description String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Giá hiển thị chính của gói
  basePrice  Int
  serviceFee Int @default(0)

  // Mô tả nhanh trên giao diện
  summary       String?
  note          String?
  isPopular     Boolean @default(false)
  isBHYTSupport Boolean @default(false)
  isActive      Boolean @default(true)

  // Chi tiết từng hạng mục trong gói khám
  items PackageItem[]

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
}

// Chi tiết gói khám
// Dùng để nói rõ gói này khám những gì và từng mục có phí bao nhiêu
model PackageItem {
  id String @id @default(uuid())

  packageId String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  name        String // VD: Khám lâm sàng, Xét nghiệm máu, Siêu âm bụng
  description String?

  // Giá của từng hạng mục. Nếu đã nằm trong gói thì có thể để 0 hoặc included = true
  price    Int     @default(0)
  included Boolean @default(true)

  // Thứ tự hiển thị trên giao diện
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
}

// ===================== APPOINTMENTS =====================

model Appointment {
  id          String @id @default(uuid())
  bookingCode String @unique

  appointmentDate DateTime
  startTime       String
  endTime         String
  status          AppointmentStatus @default(PENDING_OTP)

  reason String?

  // Thông tin đặt lịch snapshot để không mất dữ liệu nếu user đổi profile
  patientName  String
  patientPhone String
  patientEmail String?
  otpChannel   OtpChannel @default(SMS)
  patientGender Gender?
  patientDateOfBirth DateTime?
  patientAddress String?
  patientCccd String?

  hasBHYT             Boolean @default(false)
  healthInsuranceCode String?
  registeredHospital  String?
  allergies           String?
  medicalHistory      String?
  familyHistory       String?

  estimatedPrice Int @default(0)
  serviceFee     Int @default(0)
  bhytDiscount   Int @default(0)
  finalAmount    Int @default(0)

  patientId String
  patient   User   @relation("PatientAppointments", fields: [patientId], references: [id])

  doctorId String
  doctor   DoctorProfile @relation("DoctorAppointments", fields: [doctorId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  timeSlotId String?         @unique
  timeSlot   DoctorTimeSlot? @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)

  // Nếu lịch này được dời từ lịch cũ, lưu lại lịch gốc để truy vết
  rescheduledFromId String?
  rescheduledFrom   Appointment?  @relation("AppointmentReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo     Appointment[] @relation("AppointmentReschedule")
  rescheduledReason String?
  rescheduledAt     DateTime?

  cancelledByRole Role?
  cancelledById   String?
  cancelledReason String?

  medicalRecord MedicalRecord?
  prescription  Prescription?
  invoice       Invoice?
  review        Review?
  logs          AppointmentLog[]

  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([departmentId])
  @@index([appointmentDate])
  @@index([patientPhone])
  @@index([status])
  @@index([rescheduledFromId])
}

// ===================== APPOINTMENT / SCHEDULE LOGS =====================

// Lưu lịch sử thay đổi lịch hẹn: tạo lịch, xác thực OTP, dời lịch, hủy lịch, hoàn thành...
model AppointmentLog {
  id String @id @default(uuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  action AppointmentLogAction
  note   String?

  oldDate      DateTime?
  oldStartTime String?
  oldEndTime   String?

  newDate      DateTime?
  newStartTime String?
  newEndTime   String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@index([action])
  @@index([createdById])
}

// Lưu lịch sử bác sĩ/Admin điều chỉnh lịch làm việc hoặc slot khám
model ScheduleChangeLog {
  id String @id @default(uuid())

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  type ScheduleChangeType
  note String?

  date      DateTime?
  startTime String?
  endTime   String?

  createdAt DateTime @default(now())

  @@index([doctorId])
  @@index([changedById])
  @@index([type])
}

// ===================== MEDICAL RECORDS / RESULTS =====================

model MedicalRecord {
  id String @id @default(uuid())

  recordCode String @unique // Mã hồ sơ bệnh án

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId String
  patient   User   @relation("PatientRecords", fields: [patientId], references: [id])

  doctorId String
  doctor   DoctorProfile @relation("DoctorRecords", fields: [doctorId], references: [id])

  symptoms     String?
  diagnosis    String?
  treatment    String?
  prescription String?
  doctorNotes  String?

  status MedicalResultStatus @default(DRAFT)

  // File PDF kết quả hoặc hồ sơ khám nếu có
  resultPdfUrl String?

  labResults LabResult[]
  prescriptionRecord Prescription?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([recordCode])
}

model LabResult {
  id String @id @default(uuid())

  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  testName       String
  resultValue    String?
  unit           String?
  referenceRange String?
  conclusion     String?
  fileUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([medicalRecordId])
}

// Don thuoc tu do, khong quan ly kho va khong tinh gia thuoc
model Prescription {
  id String @id @default(uuid())

  prescriptionCode String @unique

  medicalRecordId String        @unique
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId String
  patient   User   @relation("PatientPrescriptions", fields: [patientId], references: [id])

  doctorId String
  doctor   DoctorProfile @relation("DoctorPrescriptions", fields: [doctorId], references: [id])

  status PrescriptionStatus @default(DRAFT)
  note   String?

  items PrescriptionItem[]

  issuedAt    DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([prescriptionCode])
  @@index([status])
}

model PrescriptionItem {
  id String @id @default(uuid())

  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  medicineName String
  dosage       String?
  frequency    String?
  duration     String?
  quantity     Int?
  unit         String?
  instruction  String?
  sortOrder    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prescriptionId])
  @@index([sortOrder])
}

// ===================== INVOICE / BARCODE LOGIN =====================

model Invoice {
  id String @id @default(uuid())

  invoiceCode String @unique
  barcode     String @unique // Mã vạch hóa đơn dùng để đăng nhập nhanh vào portal

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId String
  patient   User   @relation("PatientInvoices", fields: [patientId], references: [id])

  totalAmount  Int
  bhytDiscount Int @default(0)
  finalAmount  Int

  status        InvoiceStatus  @default(UNPAID)
  paymentMethod PaymentMethod?
  paidAt        DateTime?
  refundReason  String?
  refundedAt    DateTime?

  paymentTransactions PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barcode])
  @@index([invoiceCode])
  @@index([patientId])
}

model PaymentTransaction {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  status   PaymentTransactionStatus @default(PENDING)

  amount Int

  transactionCode String  @unique
  providerOrderId String?
  paymentUrl      String?

  rawRequest  Json?
  rawResponse Json?

  paidAt    DateTime?
  expiredAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([provider])
  @@index([status])
  @@index([transactionCode])
  @@index([providerOrderId])
  @@index([expiredAt])
}

// ===================== CHATBOT =====================

model ChatbotLog {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  sessionId String?
  session   ChatbotSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  guestPhone String?

  message  String
  response String
  intent   String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([guestPhone])
  @@index([intent])
}

model ChatbotSession {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  guestPhone String?

  draft        Json    @default("{}")
  currentIntent String?
  currentState  String?
  lastActions   Json?
  lastMessage   String?
  lastResponse  String?

  isActive  Boolean  @default(true)
  expiresAt DateTime?

  logs ChatbotLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([guestPhone])
  @@index([currentIntent])
  @@index([currentState])
  @@index([isActive])
  @@index([expiresAt])
}

model ChatbotFAQ {
  id String @id @default(uuid())

  question String
  answer   String
  keywords String[]
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatbotSetting {
  id String @id @default(uuid())

  key   String @unique
  value Json

  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ===================== PUBLIC WEB CONFIG =====================

model SiteSetting {
  id String @id @default(uuid())

  key   String @unique
  value Json

  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Banner {
  id String @id @default(uuid())

  title       String
  subtitle    String?
  image       String
  mobileImage String?
  linkUrl     String?
  target      String?
  position    String  @default("HOME_HERO")

  order    Int     @default(0)
  isActive Boolean @default(true)

  startAt DateTime?
  endAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
  @@index([isActive])
  @@index([order])
}

model PublicFAQ {
  id String @id @default(uuid())

  question String
  answer   String
  category String?

  order    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([order])
}

// ===================== CONSULTATION REQUEST =====================

model ConsultationRequest {
  id String @id @default(uuid())

  phone    String
  fullName String?
  message  String?

  status ConsultationStatus @default(NEW)
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([status])
}

// ===================== REVIEW =====================

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
}
